# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Django ---
DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Database (D1-04) ---
# Cloud Postgres, e.g. Neon: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Leave unset to fall back to local SQLite for first boot.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Celery / Redis (D1-03) ---
# Cloud Redis, e.g. Upstash / Redis Cloud (use the rediss:// TLS URL).
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Run tasks synchronously in-process (handy for local dev without a worker):
CELERY_TASK_ALWAYS_EAGER=False

# --- Credential encryption (D1-06, set when that task lands) ---
# FERNET_KEY=
