# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Django ---
DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Database (D1-04) ---
# Cloud Postgres, e.g. Neon: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Leave unset to fall back to local SQLite for first boot.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Async queue (D-108) ---
# django-q2 uses the database (DATABASE_URL) as its broker — no Redis, no extra URL.
# Run the worker with: python manage.py qcluster

# --- Credential encryption (D1-06 / SEC-02 / D-100 = Fernet) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Dev has a built-in dev key; set this in prod (Railway secret — never commit, D-106).
# FERNET_KEY=

# --- Email (handoff, D-108) ---
# RESEND_API_KEY=

# --- Meta webhook (set when channel work lands) ---
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
